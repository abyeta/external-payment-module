<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<GridPane prefHeight="500.0" prefWidth="700.0" stylesheets="@styles/external-service-styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.jala.university.presentation.controller.ExternalServiceController">

    <rowConstraints>
        <RowConstraints percentHeight="20" />
        <RowConstraints percentHeight="80" />
        <RowConstraints percentHeight="20" />
    </rowConstraints>

    <columnConstraints>
        <ColumnConstraints percentWidth="100" />
    </columnConstraints>

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
    </padding>

    <HBox spacing="10" GridPane.rowIndex="0">
        <Button fx:id="backButton" onAction="#onBackToMain" styleClass="btn-back" text="Return to Menu" />
    </HBox>

    <VBox alignment="CENTER_RIGHT" GridPane.vgrow="ALWAYS" GridPane.rowIndex="0">
        <Label text="Service name" fx:id="serviceNameLabel" styleClass="page-title" />
    </VBox>

    <VBox spacing="20" styleClass="form-container" GridPane.rowIndex="1">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>
        <Label text="Code user">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Label>
        <TextField promptText="Type the code user" style="-fx-padding: 10 10 10 10" />
        <Label fx:id="feedbackLabel" managed="false" styleClass="error-text" visible="false" wrapText="true">
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
    </VBox>

    <VBox alignment="BOTTOM_RIGHT" GridPane.rowIndex="2">
        <Button fx:id="searchButton" mnemonicParsing="false" onAction="#onSearch" styleClass="btn-primary" text="Search">
            <font>
                <Font name="System Bold" size="13.0" />
            </font>
        </Button>
    </VBox>

</GridPane>
