<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.jala.university.presentation.controller.ExternalServiceInvoicesController"
      stylesheets="@styles/external-service-styles.css"
      prefHeight="700.0" prefWidth="1100.0">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="20.0" />
    </padding>

    <HBox spacing="10">
        <Button fx:id="backButton" onAction="#onBackExternalService" styleClass="btn-back" text="Return to external service" />
    </HBox>

    <VBox alignment="CENTER_RIGHT" GridPane.rowIndex="0">
        <Label text="Service name" fx:id="serviceNameLabel" styleClass="page-title" />
    </VBox>

    <VBox styleClass="form-container" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
        </padding>
        <HBox>
            <Label text="SERVICE TYPE" style="-fx-text-fill: #6c757d; -fx-font-size: 11px; -fx-font-weight: bold; -fx-max-width: Infinity;" HBox.hgrow="ALWAYS">
                <font>
                    <Font name="System Bold" size="11.0" />
                </font>
            </Label>
            <Label text="CODE" style="-fx-text-fill: #6c757d; -fx-font-size: 11px; -fx-font-weight: bold; -fx-min-width: 200px; -fx-pref-width: 200px; -fx-max-width: 200px; -fx-alignment: CENTER_LEFT;">
                <font>
                    <Font name="System Bold" size="11.0" />
                </font>
            </Label>
            <Label text="STATUS" style="-fx-text-fill: #6c757d; -fx-font-size: 11px; -fx-font-weight: bold; -fx-min-width: 150px; -fx-pref-width: 150px; -fx-max-width: 150px; -fx-alignment: CENTER_LEFT;">
                <font>
                    <Font name="System Bold" size="11.0" />
                </font>
            </Label>
            <Label text="AMOUNT" style="-fx-text-fill: #6c757d; -fx-font-size: 11px; -fx-font-weight: bold; -fx-min-width: 150px; -fx-pref-width: 150px; -fx-max-width: 150px; -fx-alignment: CENTER_LEFT;">
                <font>
                    <Font name="System Bold" size="11.0" />
                </font>
            </Label>
            <Label text="ACTIONS" style="-fx-text-fill: #6c757d; -fx-font-size: 11px; -fx-font-weight: bold; -fx-min-width: 150px; -fx-pref-width: 150px; -fx-max-width: 150px; -fx-alignment: CENTER;">
                <font>
                    <Font name="System Bold" size="11.0" />
                </font>
            </Label>
        </HBox>
        <Separator />
        <ScrollPane fx:id="invoicesScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: white; -fx-border-color: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox fx:id="invoicesTableContainer" spacing="5" style="-fx-background-color: white;" />
        </ScrollPane>
    </VBox>

</VBox>
