<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox fx:id="root" xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.jala.university.presentation.controller.MainMenuController"
      prefHeight="800.0" prefWidth="1200.0"
      stylesheets="@styles/external-service-styles.css"
      styleClass="root-container">

    <padding>
        <Insets top="40.0" right="50.0" bottom="40.0" left="50.0" />
    </padding>

    <!-- Return to Menu Button -->
    <HBox alignment="CENTER_LEFT" spacing="10" VBox.vgrow="NEVER">
      <Button fx:id="returnButton"
        text="← Return to Menu"
        onAction="#backToMenu"
        style="-fx-background-color: #e7f2fc; -fx-text-fill: #0d5fb3; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 16; -fx-cursor: hand;">
        <font>
          <Font size="13.0" />
        </font>
      </Button>
    </HBox>

  <!-- Header Section -->
    <HBox alignment="CENTER_LEFT" spacing="20.0" VBox.vgrow="NEVER">
        <VBox.margin>
            <Insets bottom="30.0" />
        </VBox.margin>

        <!-- Title and Description -->
        <VBox spacing="8.0" HBox.hgrow="ALWAYS">
            <Label text="External Services Management" styleClass="page-title">
                <font>
                    <Font name="System Bold" size="32.0" />
                </font>
            </Label>
            <Label text="Manage integrations with external services." styleClass="page-description">
                <font>
                    <Font size="15.0" />
                </font>
            </Label>
        </VBox>

        <!-- Add New Service Button -->
        <Button fx:id="addButton" text="+ Add Service" onAction="#onRegisterService" styleClass="btn-primary">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>
    </HBox>

    <!-- Main Content Container with Table -->
    <VBox spacing="0" styleClass="form-container" VBox.vgrow="ALWAYS">
        <padding>
            <Insets top="30.0" right="30.0" bottom="30.0" left="30.0" />
        </padding>

        <!-- Table Header -->
        <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-padding: 18 20; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 2 0;">
            <Label text="SERVICE NAME" style="-fx-text-fill: #6c757d; -fx-font-size: 11px; -fx-font-weight: bold; -fx-max-width: Infinity;" HBox.hgrow="ALWAYS">
                <font>
                    <Font name="System Bold" size="11.0" />
                </font>
            </Label>
            <Label text="REGISTRATION CODE" style="-fx-text-fill: #6c757d; -fx-font-size: 11px; -fx-font-weight: bold; -fx-min-width: 200px; -fx-pref-width: 200px; -fx-max-width: 200px; -fx-alignment: CENTER_LEFT;">
                <font>
                    <Font name="System Bold" size="11.0" />
                </font>
            </Label>
            <Label text="STATUS" style="-fx-text-fill: #6c757d; -fx-font-size: 11px; -fx-font-weight: bold; -fx-min-width: 150px; -fx-pref-width: 150px; -fx-max-width: 150px; -fx-alignment: CENTER_LEFT;">
                <font>
                    <Font name="System Bold" size="11.0" />
                </font>
            </Label>
            <Label text="ACTIONS" style="-fx-text-fill: #6c757d; -fx-font-size: 11px; -fx-font-weight: bold; -fx-min-width: 150px; -fx-pref-width: 150px; -fx-max-width: 150px; -fx-alignment: CENTER;">
                <font>
                    <Font name="System Bold" size="11.0" />
                </font>
            </Label>
        </HBox>

        <!-- Services List (Table Rows) -->
        <ScrollPane fx:id="servicesScrollPane" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: white; -fx-border-color: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox fx:id="servicesTableContainer" spacing="0" style="-fx-background-color: white;" />
        </ScrollPane>

        <!-- Message/Feedback Label -->
        <Label fx:id="message" visible="false" managed="false" styleClass="feedback-label info" wrapText="true">
            <VBox.margin>
                <Insets top="20.0" />
            </VBox.margin>
            <font>
                <Font name="System Bold" size="12.0" />
            </font>
        </Label>
    </VBox>

    <VBox fx:id="confirmBox"
      alignment="CENTER"
      visible="false" managed="false"
      prefWidth="520" prefHeight="160">
      <Label fx:id="confirmMessage" text="Are you sure?" maxWidth="420"/>
      <HBox spacing="12" alignment="CENTER">
        <Button fx:id="confirmYes" text="Yes"/>
        <Button fx:id="confirmNo" text="No"/>
      </HBox>
    </VBox>


</VBox>
