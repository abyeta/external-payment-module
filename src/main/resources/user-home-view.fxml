<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.jala.university.presentation.controller.UserHomeController"
      prefWidth="800.0" prefHeight="700.0"
      style="-fx-background-color: #f8f9fa;">

  <padding>
    <Insets top="40" right="50" bottom="40" left="50"/>
  </padding>

  <!-- Back Button (Top Left) -->
  <HBox alignment="CENTER_LEFT">
    <VBox.margin>
      <Insets bottom="16"/>
    </VBox.margin>
    <Button text="← Return to Menu"
            onAction="#backToMenu"
            style="-fx-background-color: transparent; -fx-text-fill: #007bff; -fx-font-size: 14px; -fx-underline: false; -fx-cursor: hand; -fx-padding: 4 8; -fx-border-width: 0;">
      <font>
        <Font size="14.0"/>
      </font>
    </Button>
  </HBox>

  <!-- Title -->
  <Label text="🔍 Search for External Services" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #212529;">
    <font>
      <Font name="System Bold" size="24.0"/>
    </font>
    <VBox.margin>
      <Insets bottom="8"/>
    </VBox.margin>
  </Label>

  <!-- Subtitle -->
  <Label text="Search and link external payment services to your bank account" style="-fx-font-size: 13px; -fx-text-fill: #6c757d;">
    <VBox.margin>
      <Insets bottom="24"/>
    </VBox.margin>
  </Label>

  <!-- Search Bar -->
  <HBox spacing="12" alignment="CENTER_LEFT">
    <VBox.margin>
      <Insets bottom="32"/>
    </VBox.margin>

    <TextField fx:id="searchField"
               promptText="🔍 Search by name, email or phone..."
               styleClass="text-field"
               HBox.hgrow="ALWAYS"
               onAction="#onSearch"
               style="-fx-pref-height: 45px; -fx-font-size: 14px; -fx-background-color: white; -fx-border-color: #ced4da; -fx-border-radius: 6px; -fx-background-radius: 6px;">
      <font>
        <Font size="14.0"/>
      </font>
    </TextField>

    <Button fx:id="searchButton"
            text="Search"
            onAction="#onSearch"
            prefWidth="120"
            prefHeight="45"
            style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;">
      <font>
        <Font name="System Bold" size="14.0"/>
      </font>
    </Button>
  </HBox>

  <!-- Results Section -->
  <VBox spacing="12" VBox.vgrow="ALWAYS">
    <!-- Results Header -->
    <Label text="Search Results" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #212529;">
      <font>
        <Font name="System Bold" size="15.0"/>
      </font>
      <VBox.margin>
        <Insets top="4"/>
      </VBox.margin>
    </Label>

    <!-- Results Container -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                style="-fx-background-color: transparent; -fx-border-width: 0;">
      <VBox fx:id="resultsContainer" 
            spacing="0" 
            style="-fx-background-color: #e9ecef; -fx-padding: 20px; -fx-background-radius: 6px;"
            minHeight="200">
        <Label fx:id="emptyResultsLabel" 
               text="Enter a search term to begin" 
               style="-fx-font-size: 13px; -fx-text-fill: #007bff; -fx-padding: 40px; -fx-alignment: center;"
               alignment="CENTER"
               maxWidth="Infinity"/>
      </VBox>
    </ScrollPane>

    <!-- Linked Services Section -->
    <VBox spacing="12" style="-fx-padding: 20 0 0 0;">
      <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="✅ My Linked Services" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #212529;">
          <font>
            <Font name="System Bold" size="15.0"/>
          </font>
        </Label>
        <Label fx:id="linkedCount" text="0" style="-fx-font-size: 14px; -fx-text-fill: #6c757d; -fx-background-color: #e9ecef; -fx-padding: 2 8; -fx-background-radius: 10;">
          <font>
            <Font size="14.0"/>
          </font>
        </Label>
      </HBox>

      <!-- Linked Services Container -->
      <VBox fx:id="linkedServicesContainer" spacing="12"/>
    </VBox>
  </VBox>

  <!-- Confirmation Dialog Overlay -->
  <StackPane fx:id="overlayPane" visible="false" managed="false"
             style="-fx-background-color: rgba(0, 0, 0, 0.5);">
    <VBox fx:id="confirmBox"
          alignment="CENTER"
          spacing="24"
          style="-fx-background-color: white; -fx-background-radius: 12px; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 20, 0, 0, 4); -fx-max-width: 450px;">

      <Label fx:id="confirmMessage"
             text="Confirm action?"
             wrapText="true"
             style="-fx-text-fill: #212529; -fx-font-size: 16px; -fx-text-alignment: center;">
        <font>
          <Font name="System Bold" size="16.0"/>
        </font>
      </Label>

      <HBox spacing="12" alignment="CENTER">
        <Button fx:id="confirmNo"
                text="Cancel"
                prefWidth="120"
                prefHeight="42"
                onAction="#onConfirmNo"
                style="-fx-background-color: #e9ecef; -fx-text-fill: #495057; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;">
        </Button>
        <Button fx:id="confirmYes"
                text="Confirm"
                prefWidth="120"
                prefHeight="42"
                onAction="#onConfirmYes"
                style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 6px; -fx-cursor: hand;">
        </Button>
      </HBox>
    </VBox>
  </StackPane>

</VBox>
