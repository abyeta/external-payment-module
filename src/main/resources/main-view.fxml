<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="500.0" prefWidth="700.0" spacing="30.0" style="-fx-background-color: #f8f9fa;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.jala.university.presentation.controller.MainViewController">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <!-- Header -->
    <VBox alignment="CENTER" spacing="10.0">
        <Label text="Módulo de Pagos Externos" style="-fx-text-fill: #1a1a1a;">
            <font>
                <Font name="System Bold" size="32.0" />
            </font>
        </Label>
        <Label text="Sistema de Gestión de Servicios Externos" style="-fx-text-fill: #6c757d;">
            <font>
                <Font size="16.0" />
            </font>
        </Label>
    </VBox>

    <!-- Menu Options -->
    <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 12px; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
        <padding>
            <Insets bottom="30.0" left="50.0" right="50.0" top="30.0" />
        </padding>

        <Label text="¿Qué deseas hacer?" style="-fx-text-fill: #212529;">
            <font>
                <Font name="System Bold" size="18.0" />
            </font>
        </Label>

        <Button mnemonicParsing="false" onAction="#onRegisterService" prefWidth="300.0" style="-fx-background-color: #1173d4; -fx-text-fill: white; -fx-background-radius: 8px; -fx-padding: 15px 30px; -fx-cursor: hand;" text="Registrar Servicio Externo">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>

        <Button mnemonicParsing="false" prefWidth="300.0" style="-fx-background-color: #e9ecef; -fx-text-fill: #495057; -fx-background-radius: 8px; -fx-padding: 15px 30px; -fx-cursor: hand;" text="Ver Servicios Registrados">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>

        <Button mnemonicParsing="false" prefWidth="300.0" style="-fx-background-color: #e9ecef; -fx-text-fill: #495057; -fx-background-radius: 8px; -fx-padding: 15px 30px; -fx-cursor: hand;" text="Configuración">
            <font>
                <Font name="System Bold" size="14.0" />
            </font>
        </Button>
    </VBox>

    <!-- Footer -->
    <Label text="External Payment Module v1.0" style="-fx-text-fill: #adb5bd;">
        <font>
            <Font size="12.0" />
        </font>
    </Label>
</VBox>
